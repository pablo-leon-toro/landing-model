---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Tu Landing Page - Soluciones Digitales"
  description="Transformamos tu negocio con soluciones digitales innovadoras"
  keywords="landing page, desarrollo web, soluciones digitales"
>
  <Header brandName="DigitalCorp" />
  
  <main>
    <!-- Hero Section -->
    <section id="inicio" class="hero">
      <div class="container">
        <div class="hero__content">
          <div class="hero__text">
            <h1 class="hero__title">
              Transformamos tu <span class="highlight">negocio digital</span>
            </h1>
            <p class="hero__subtitle lead">
              Creamos experiencias digitales excepcionales que conectan con tu audiencia 
              y impulsan el crecimiento de tu empresa.
            </p>
            <div class="hero__actions">
              <a href="#contacto" class="btn btn--primary btn--large">
                Empezar ahora
              </a>
              <a href="#servicios" class="btn btn--secondary btn--large">
                Ver servicios
              </a>
            </div>
          </div>
          <div class="hero__visual">
            <div class="hero__image">
              <div class="placeholder-image">🚀</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="servicios" class="section">
      <div class="container">
        <div class="section__header text-center">
          <h2>Nuestros Servicios</h2>
          <p class="lead">
            Ofrecemos soluciones completas para llevar tu negocio al siguiente nivel
          </p>
        </div>
        
        <div class="grid grid--3">
          <div class="card service-card">
            <div class="service-card__icon">💻</div>
            <h3>Desarrollo Web</h3>
            <p>
              Sitios web modernos, rápidos y optimizados para todos los dispositivos.
              Tecnologías de vanguardia para resultados excepcionales.
            </p>
            <a href="#contacto" class="service-card__link">Saber más →</a>
          </div>

          <div class="card service-card">
            <div class="service-card__icon">🎨</div>
            <h3>Diseño UX/UI</h3>
            <p>
              Experiencias de usuario intuitivas y atractivas que convierten 
              visitantes en clientes satisfechos.
            </p>
            <a href="#contacto" class="service-card__link">Saber más →</a>
          </div>

          <div class="card service-card">
            <div class="service-card__icon">📱</div>
            <h3>Apps Móviles</h3>
            <p>
              Aplicaciones nativas e híbridas que funcionan perfectamente 
              en iOS y Android.
            </p>
            <a href="#contacto" class="service-card__link">Saber más →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="acerca" class="section" style="background: var(--bg-secondary);">
      <div class="container">
        <div class="about">
          <div class="about__content">
            <h2>¿Por qué elegirnos?</h2>
            <p class="lead">
              Con más de 5 años de experiencia, hemos ayudado a cientos de empresas 
              a digitalizar sus procesos y alcanzar sus objetivos.
            </p>
            
            <div class="stats">
              <div class="stat">
                <div class="stat__number">200+</div>
                <div class="stat__label">Proyectos completados</div>
              </div>
              <div class="stat">
                <div class="stat__number">150+</div>
                <div class="stat__label">Clientes satisfechos</div>
              </div>
              <div class="stat">
                <div class="stat__number">99%</div>
                <div class="stat__label">Tasa de satisfacción</div>
              </div>
            </div>

            <div class="features">
              <div class="feature">
                <div class="feature__icon">⚡</div>
                <div class="feature__content">
                  <h4>Entrega rápida</h4>
                  <p>Metodologías ágiles para resultados en tiempo récord</p>
                </div>
              </div>
              
              <div class="feature">
                <div class="feature__icon">🎯</div>
                <div class="feature__content">
                  <h4>Enfoque personalizado</h4>
                  <p>Cada proyecto es único, como tu negocio</p>
                </div>
              </div>
              
              <div class="feature">
                <div class="feature__icon">🔧</div>
                <div class="feature__content">
                  <h4>Soporte continuo</h4>
                  <p>Te acompañamos después del lanzamiento</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="about__visual">
            <div class="placeholder-image large">📊</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="section">
      <div class="container">
        <div class="section__header text-center">
          <h2>Lo que dicen nuestros clientes</h2>
          <p class="lead">La satisfacción de nuestros clientes es nuestra mayor recompensa</p>
        </div>
        
        <div class="grid grid--2">
          <div class="testimonial card">
            <div class="testimonial__content">
              <p>"Increíble trabajo. El equipo superó todas nuestras expectativas y entregó 
              un producto de calidad excepcional."</p>
            </div>
            <div class="testimonial__author">
              <div class="testimonial__avatar">👤</div>
              <div class="testimonial__info">
                <div class="testimonial__name">María González</div>
                <div class="testimonial__role">CEO, TechStart</div>
              </div>
            </div>
          </div>

          <div class="testimonial card">
            <div class="testimonial__content">
              <p>"Profesionales, puntuales y con gran atención al detalle. 
              Definitivamente los recomendaría."</p>
            </div>
            <div class="testimonial__author">
              <div class="testimonial__avatar">👤</div>
              <div class="testimonial__info">
                <div class="testimonial__name">Carlos Ruiz</div>
                <div class="testimonial__role">Director, InnovaCorp</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contacto" class="section contact-section">
      <div class="container">
        <div class="contact">
          <div class="contact__content">
            <h2>¿Listo para empezar?</h2>
            <p class="lead">
              Cuéntanos sobre tu proyecto y te ayudaremos a hacerlo realidad
            </p>
            
            <div class="contact__info">
              <div class="contact__item">
                <div class="contact__icon">📧</div>
                <div>
                  <h4>Email</h4>
                  <p>hola@digitalcorp.com</p>
                </div>
              </div>
              
              <div class="contact__item">
                <div class="contact__icon">📱</div>
                <div>
                  <h4>Teléfono</h4>
                  <p>+56 9 1234 5678</p>
                </div>
              </div>
              
              <div class="contact__item">
                <div class="contact__icon">📍</div>
                <div>
                  <h4>Ubicación</h4>
                  <p>Santiago, Chile</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="contact__form">
            <form class="form">
              <div class="form__group">
                <label for="name" class="form__label">Nombre</label>
                <input type="text" id="name" name="name" class="form__input" required>
              </div>
              
              <div class="form__group">
                <label for="email" class="form__label">Email</label>
                <input type="email" id="email" name="email" class="form__input" required>
              </div>
              
              <div class="form__group">
                <label for="message" class="form__label">Mensaje</label>
                <textarea id="message" name="message" rows="5" class="form__input" required></textarea>
              </div>
              
              <button type="submit" class="btn btn--primary btn--large" style="width: 100%;">
                Enviar mensaje
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer brandName="DigitalCorp" />
</Layout>

<style>
  /* Hero Section */
  .hero {
    padding: calc(80px + var(--space-4xl)) 0 var(--space-4xl);
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: var(--text-inverse);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .hero__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
    color: var(--text-inverse);
  }

  .highlight {
    background: linear-gradient(45deg, #ffd700, #ffed4e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: 1.25rem;
    margin-bottom: var(--space-xl);
    color: rgba(255, 255, 255, 0.9);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__image {
    width: 100%;
    max-width: 400px;
  }

  /* Service Cards */
  .service-card {
    text-align: center;
    transition: transform var(--transition-normal);
  }

  .service-card:hover {
    transform: translateY(-8px);
  }

  .service-card__icon {
    font-size: 3rem;
    margin-bottom: var(--space-lg);
  }

  .service-card__link {
    display: inline-block;
    margin-top: var(--space-md);
    color: var(--brand-primary);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .service-card__link:hover {
    color: var(--brand-secondary);
    text-decoration: none;
  }

  /* About Section */
  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin: var(--space-xl) 0;
  }

  .stat {
    text-align: center;
  }

  .stat__number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--brand-primary);
    line-height: 1;
  }

  .stat__label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: var(--space-sm);
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .feature {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .feature__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .feature__content h4 {
    margin-bottom: var(--space-sm);
  }

  .feature__content p {
    margin-bottom: 0;
    color: var(--text-secondary);
  }

  /* Testimonials */
  .testimonial {
    padding: var(--space-xl);
  }

  .testimonial__content {
    margin-bottom: var(--space-lg);
  }

  .testimonial__content p {
    font-style: italic;
    font-size: 1.125rem;
    margin-bottom: 0;
  }

  .testimonial__author {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .testimonial__avatar {
    width: 48px;
    height: 48px;
    background: var(--bg-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .testimonial__name {
    font-weight: 600;
    color: var(--text-primary);
  }

  .testimonial__role {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Contact Section */
  .contact-section {
    background: var(--bg-secondary);
  }

  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .contact__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .contact__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .contact__item h4 {
    margin-bottom: var(--space-xs);
  }

  .contact__item p {
    margin-bottom: 0;
    color: var(--text-secondary);
  }

  /* Form Styles */
  .form {
    background: var(--bg-primary);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .form__group {
    margin-bottom: var(--space-lg);
  }

  .form__label {
    display: block;
    margin-bottom: var(--space-sm);
    font-weight: 500;
    color: var(--text-primary);
  }

  .form__input {
    width: 100%;
    padding: var(--space-md);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    font-size: 1rem;
    background: var(--bg-primary);
    color: var(--text-primary);
    transition: border-color var(--transition-fast);
  }

  .form__input:focus {
    outline: none;
    border-color: var(--brand-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  textarea.form__input {
    resize: vertical;
    min-height: 120px;
  }

  /* Placeholder Images */
  .placeholder-image {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    font-size: 4rem;
    aspect-ratio: 4/3;
    backdrop-filter: blur(10px);
  }

  .placeholder-image.large {
    font-size: 6rem;
  }

  /* Section Headers */
  .section__header {
    margin-bottom: var(--space-4xl);
  }

  .section__header h2 {
    margin-bottom: var(--space-md);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .hero__content,
    .about,
    .contact {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .stats {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-md);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: calc(80px + var(--space-2xl)) 0 var(--space-2xl);
      text-align: center;
    }

    .hero__actions {
      justify-content: center;
    }

    .stats {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .features {
      text-align: center;
    }

    .feature {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .contact__info {
      order: 2;
    }

    .contact__form {
      order: 1;
    }
  }

  @media (max-width: 480px) {
    .hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .hero__actions .btn {
      width: 100%;
      max-width: 280px;
    }

    .form {
      padding: var(--space-lg);
    }
  }
</style>